# OMEGA AI Web Platform Configuration
# Copy this file to .env.local and update values as needed

# Adapter Configuration
# Options: "mock" (default) or "http"
NEXT_PUBLIC_ADAPTER_PROVIDER=mock

# HTTP Adapter Configuration (only used when NEXT_PUBLIC_ADAPTER_PROVIDER=http)
NEXT_PUBLIC_ADAPTER_HTTP_BASE_URL=http://localhost:8000
NEXT_PUBLIC_ADAPTER_HTTP_TIMEOUT=30000
NEXT_PUBLIC_ADAPTER_HTTP_RETRIES=3

# Enable mock fallback when HTTP requests fail
NEXT_PUBLIC_ADAPTER_ENABLE_MOCK_FALLBACK=true

# Feature Flags
NEXT_PUBLIC_ENABLE_MARKETS=true
NEXT_PUBLIC_ENABLE_AI=true
NEXT_PUBLIC_ENABLE_KNOWLEDGE=true
NEXT_PUBLIC_ENABLE_STRATEGIES=true
NEXT_PUBLIC_ENABLE_BACKTEST=true
NEXT_PUBLIC_ENABLE_PAPER=true
NEXT_PUBLIC_ENABLE_PORTFOLIO=true
NEXT_PUBLIC_ENABLE_TRADES=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_CHAT=true
NEXT_PUBLIC_ENABLE_NEWS=true
NEXT_PUBLIC_ENABLE_ADMIN=true
NEXT_PUBLIC_ENABLE_SETTINGS=true
